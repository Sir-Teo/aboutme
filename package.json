{
  "name": "aboutme",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "npm run eslint",
    "eslint": "./node_modules/.bin/eslint \"app/**/*.{js,jsx,ts,tsx}\"",
    "check-types": "tsc --noemit",
    "test": "vitest run",
    "test:watch": "vitest",
    "eslint:commit": "./node_modules/.bin/eslint --quiet",
    "eslint:quiet": "./node_modules/.bin/eslint \"app/**/*.{js,jsx,ts,tsx}\" --quiet",
    "prettier:single": "./node_modules/.bin/prettier --single-quote --no-semi --trailing-comma es5 --print-width 120 --tab-width 4 --arrow-parens avoid --write",
    "prettier": "./node_modules/.bin/prettier --single-quote --no-semi --trailing-comma es5 --print-width 120 --tab-width 4 --arrow-parens avoid --write \"app/**/*.{js,jsx,ts,tsx}\"",
    "prettier:svg": "./node_modules/.bin/prettier --single-quote --no-semi --trailing-comma es5 --print-width 120 --tab-width 4 --arrow-parens avoid --write \"public/**/*.svg\"",
    "prettier:check": "./node_modules/.bin/prettier --single-quote --no-semi --trailing-comma es5 --print-width 120 --tab-width 4 --arrow-parens avoid --check \"app/**/*.{js,jsx,ts,tsx}\"",
    "lint-staged": "lint-staged"
  },
  "precommit": "lint-staged",
  "eslintConfig": {
    "extends": "next/core-web-vitals"
  },
  "lint-staged": {
    "app/**/*.{js,jsx,ts,tsx}": [
      "npm run eslint:commit --",
      "prettier --single-quote --no-semi --trailing-comma es5 --print-width 120 --tab-width 4 --arrow-parens avoid --write"
    ]
  },
  "dependencies": {
    "@types/node": "20.4.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.14",
    "eslint": "8.45.0",
    "eslint-config-next": "15.5.19",
    "next": "16.2.9",
    "postcss": "^8.5.15",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "3.3.3",
    "typescript": "5.1.6"
  },
  "devDependencies": {
    "lint-staged": "^13.2.2",
    "pre-commit": "^2.0.0",
    "prettier": "^2.8.8",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "glob": "^11.1.0",
    "postcss": "^8.5.15"
  }
}
